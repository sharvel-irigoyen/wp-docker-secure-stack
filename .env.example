# ============================================================================
# WordPress Docker Infrastructure - Environment Variables
# ============================================================================
# Copy this file to .env and update the values:
#   cp .env.example .env
#
# Or use the setup script to generate secure passwords automatically:
#   bash scripts/setup.sh
#
# IMPORTANT: NEVER commit .env to version control
# ============================================================================

# ── Project ──────────────────────────────────────────────────────────────────
# Used as prefix for container names and volume names
COMPOSE_PROJECT_NAME=wordpress-site

# ── Nginx Proxy Manager ─────────────────────────────────────────────────────
# External Docker network shared with Nginx Proxy Manager
# Run: docker network ls  to find the correct network name
PROXY_NETWORK=proxy_net

# ── MySQL 8.0 Database ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_use_setup_script
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wp_user
MYSQL_PASSWORD=CHANGE_ME_use_setup_script

# ── WordPress ────────────────────────────────────────────────────────────────
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_NAME=wordpress_db
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=CHANGE_ME_use_setup_script
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false

# ── Redis Object Cache ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_use_setup_script

# ── WordPress Docker Image Version ──────────────────────────────────────────
# See: https://hub.docker.com/_/wordpress/tags
WORDPRESS_VERSION=6-php8.3-fpm-alpine

# ── Local Development ───────────────────────────────────────────────────────
# Define el puerto local si quieres entrar a http://localhost:8087 sin usar NPM
# En producción, usar 127.0.0.1:8087 lo hace seguro al no exponerlo a internet
LOCAL_PORT=8087
